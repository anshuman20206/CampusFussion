
{
  "entities": {
    "Internship": {
      "title": "Internship",
      "type": "object",
      "description": "Represents an internship opportunity.",
      "properties": {
        "companyName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "location": { "type": "string", "enum": ["Remote", "Onsite", "Hybrid"] },
        "domain": { "type": "string", "enum": ["Web Dev", "AI", "Data Science", "Marketing", "Design", "Other"] },
        "duration": "Duration of internship",
        "stipend": { "type": "string" },
        "skillsRequired": { "type": "array", "items": { "type": "string" } },
        "deadline": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "title", "location", "deadline"]
    },
    "InternshipApplication": {
      "title": "InternshipApplication",
      "type": "object",
      "description": "Represents a student's application for an internship.",
      "properties": {
        "internshipId": { "type": "string" },
        "internshipTitle": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "college": { "type": "string" },
        "branch": { "type": "string" },
        "year": { "type": "string" },
        "phone": { "type": "string" },
        "resumeUrl": { "type": "string", "format": "uri" },
        "portfolioUrl": { "type": "string", "format": "uri" },
        "statement": { "type": "string" },
        "appliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "resumeUrl", "internshipId"]
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "Represents a campus event.",
      "properties": {
        "name": { "type": "string" },
        "organizer": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "bannerUrl": { "type": "string", "format": "uri" }
      },
      "required": ["name", "organizer", "date", "location"]
    },
    "EventRegistration": {
      "title": "EventRegistration",
      "type": "object",
      "description": "Represents a student's registration for an event.",
      "properties": {
        "eventId": { "type": "string" },
        "eventName": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "college": { "type": "string" },
        "phone": { "type": "string" },
        "registeredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "eventId"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/internships/{id}": { "schema": "Internship", "description": "Internship opportunities." },
    "/internshipApplications/{id}": { "schema": "InternshipApplication", "description": "Submitted applications." },
    "/events/{id}": { "schema": "Event", "description": "Campus events." },
    "/eventRegistrations/{id}": { "schema": "EventRegistration", "description": "Event attendee list." }
  }
}
