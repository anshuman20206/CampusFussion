
{
  "entities": {
    "Internship": {
      "title": "Internship",
      "type": "object",
      "description": "Represents an internship opportunity.",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "stipend": { "type": "string" },
        "description": { "type": "string" },
        "applyLink": { "type": "string", "format": "uri" },
        "deadline": { "type": "string", "format": "date" },
        "postedAt": { "type": "string", "format": "date-time" },
        "domain": { "type": "string" }
      },
      "required": ["title", "company", "location", "deadline"]
    },
    "Application": {
      "title": "Application",
      "type": "object",
      "description": "Represents a student application with social profiles.",
      "properties": {
        "studentName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "linkedinURL": { "type": "string", "format": "uri" },
        "githubURL": { "type": "string", "format": "uri" },
        "leetcodeURL": { "type": "string", "format": "uri" },
        "internshipId": { "type": "string" },
        "appliedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentName", "email", "internshipId", "linkedinURL"]
    },
    "Event": {
      "title": "Event",
      "type": "object",
      "description": "Represents a campus event.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "registrationLink": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "bannerUrl": { "type": "string", "format": "uri" }
      },
      "required": ["title", "date", "location"]
    },
    "Announcement": {
      "title": "Announcement",
      "type": "object",
      "description": "Represents a community announcement.",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "pinned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/internships/{id}": { "schema": "Internship", "description": "Internship opportunities." },
    "/applications/{id}": { "schema": "Application", "description": "Student applications." },
    "/events/{id}": { "schema": "Event", "description": "Campus events." },
    "/announcements/{id}": { "schema": "Announcement", "description": "News and updates." }
  }
}
