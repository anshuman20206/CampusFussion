
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // WARNING: These rules are permissive and are not suitable for production.
    // They allow any authenticated user to read and write to the entire database.
    // This is to unblock development and should be secured before launch.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
