
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // WARNING: These rules are permissive and are not suitable for production.
    // They allow any authenticated user to read and write to any collection.
    // This is to unblock development and should be secured before launch.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
  }
}
