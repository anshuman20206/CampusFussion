
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Internships, Events, and Announcements
    // Anyone can see these, but only logged-in admins can create/edit/delete.
    match /internships/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /events/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /announcements/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Internship Applications
    // Anyone can 'create' (submit) an application.
    // Only logged-in admins can 'read' or 'list' them.
    match /internshipApplications/{id} {
      allow create: if true;
      allow read, list: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // 3. Event Registrations
    // Anyone can register for an event.
    // Only admins can see the attendee list.
    match /eventRegistrations/{id} {
      allow create: if true;
      allow read, list: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // 4. Blog Posts (Service feature)
    match /blogs/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
