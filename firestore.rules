
rules_version = '2';

// Security Rules for CampusFussion
// Deployment Trigger: Project switched to campusfussion
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Internships, Events, and Announcements
    // Publicly readable for students; writable only by authenticated Admin.
    match /internships/{id} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }
    
    match /events/{id} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }
    
    match /announcements/{id} {
      allow read, get, list: if true;
      allow write: if request.auth != null;
    }

    // 2. Applications
    // Anyone can submit (create) an application.
    // Only authenticated Admins can view (read/list) them.
    match /applications/{id} {
      allow create: if true;
      allow read, list, delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // 3. Blog Posts
    match /blogs/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
